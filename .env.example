PORT=3000
NODE_ENV=development

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS origin (defaults to http://localhost:5173 in dev)
CLIENT_ORIGIN=http://localhost:5173

# Credential encryption (required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=generate-a-random-32-byte-hex-string
